<UserControl x:Class="SoMan.Views.TaskListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <Grid>
        <DockPanel Margin="24">
            <!-- Header -->
            <TextBlock DockPanel.Dock="Top" Text="Tasks" FontSize="24" FontWeight="Bold" Margin="0,0,0,16"/>

            <!-- Control Bar -->
            <materialDesign:Card DockPanel.Dock="Top" Padding="16" Margin="0,0,0,12">
                <StackPanel>
                    <!-- Row 1: Template + Account picker + Run buttons -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <ComboBox Grid.Column="0" materialDesign:HintAssist.Hint="Template"
                                  ItemsSource="{Binding Templates}"
                                  SelectedItem="{Binding SelectedTemplate}"
                                  DisplayMemberPath="Name"
                                  Style="{StaticResource MaterialDesignOutlinedComboBox}" Margin="0,0,12,0"/>

                        <!-- Account multi-select picker — clickable Border that opens the
                             popup. Using Border + MouseBinding (rather than a styled
                             ToggleButton) avoids inheriting the OS button theme, which on
                             dark MaterialDesign was rendering the toggle's text in black-
                             on-dark-card so it looked empty. Explicit foreground/border. -->
                        <Border x:Name="AccountPickerToggle" Grid.Column="1"
                                Margin="0,0,12,0"
                                MinHeight="56"
                                Background="Transparent"
                                BorderBrush="{DynamicResource MaterialDesignDivider}"
                                BorderThickness="1.5"
                                CornerRadius="4"
                                Cursor="Hand"
                                ToolTip="Pick accounts and/or categories">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="BorderBrush" Value="{DynamicResource PrimaryHueMidBrush}"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Border.InputBindings>
                                <MouseBinding Gesture="LeftClick"
                                              Command="{Binding OpenAccountPickerCommand}"/>
                            </Border.InputBindings>
                            <Grid Margin="12,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="Accounts" FontSize="10" Opacity="0.6"
                                               Foreground="{DynamicResource MaterialDesignBody}"
                                               Margin="0,0,0,2"/>
                                    <TextBlock Text="{Binding AccountSelectionSummary}"
                                               FontSize="14" FontWeight="Medium"
                                               Foreground="{DynamicResource MaterialDesignBody}"
                                               TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                                <materialDesign:PackIcon Grid.Column="1" Kind="MenuDown"
                                                         Width="22" Height="22"
                                                         Foreground="{DynamicResource MaterialDesignBody}"
                                                         VerticalAlignment="Center"
                                                         Margin="8,0,4,0"
                                                         Opacity="0.7"/>
                            </Grid>
                        </Border>

                        <!-- Popup floats over the toggle and contains the Categories/Accounts tabs.
                             AllowsTransparency=False so it gets a real Win32 window with an
                             opaque hit-test surface — otherwise clicks on the transparent card
                             area were treated as "outside" and StaysOpen=False closed it. -->
                        <Popup PlacementTarget="{Binding ElementName=AccountPickerToggle}"
                               Placement="Bottom"
                               IsOpen="{Binding IsAccountPickerOpen, Mode=TwoWay}"
                               StaysOpen="False" AllowsTransparency="False">
                            <materialDesign:Card Width="420" Padding="0" Margin="0,4,0,0"
                                                 Background="{DynamicResource MaterialDesignPaper}">
                                <DockPanel>
                                    <!-- Footer with Done button -->
                                    <Border DockPanel.Dock="Bottom"
                                            BorderThickness="0,1,0,0"
                                            BorderBrush="{DynamicResource MaterialDesignDivider}"
                                            Padding="12,8">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" VerticalAlignment="Center"
                                                       Text="{Binding AccountSelectionSummary}"
                                                       Opacity="0.7" FontSize="12"/>
                                            <Button Grid.Column="1" Content="Done"
                                                    Style="{StaticResource MaterialDesignFlatButton}"
                                                    Command="{Binding CloseAccountPickerCommand}"/>
                                        </Grid>
                                    </Border>

                                    <TabControl Style="{StaticResource MaterialDesignTabControl}">
                                        <!-- Categories tab -->
                                        <TabItem Header="Categories">
                                            <DockPanel Margin="0">
                                                <TextBlock DockPanel.Dock="Top" Margin="12,8,12,4"
                                                           Text="Click '+ Add' to add all accounts in a category to your selection. '−' removes them."
                                                           FontSize="11" Opacity="0.7" TextWrapping="Wrap"/>
                                                <ItemsControl ItemsSource="{Binding CategoryPicks}" MaxHeight="320">
                                                    <ItemsControl.Template>
                                                        <ControlTemplate>
                                                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                                                <ItemsPresenter/>
                                                            </ScrollViewer>
                                                        </ControlTemplate>
                                                    </ItemsControl.Template>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Grid Margin="12,4">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                </Grid.ColumnDefinitions>
                                                                <Border Grid.Column="0" Width="10" Height="10" CornerRadius="5"
                                                                        VerticalAlignment="Center" Margin="0,0,8,0">
                                                                    <Border.Background>
                                                                        <SolidColorBrush Color="{Binding Color, FallbackValue=#2196F3}"/>
                                                                    </Border.Background>
                                                                </Border>
                                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                                    <TextBlock Text="{Binding Name}" FontWeight="Medium"/>
                                                                    <TextBlock FontSize="11" Opacity="0.6">
                                                                        <Run Text="{Binding AccountCount, Mode=OneWay}"/>
                                                                        <Run Text=" account(s)"/>
                                                                    </TextBlock>
                                                                </StackPanel>
                                                                <Button Grid.Column="2" Content="+ Add"
                                                                        Style="{StaticResource MaterialDesignFlatButton}"
                                                                        FontSize="11" Padding="8,4" Height="28"
                                                                        Margin="0,0,4,0"
                                                                        Command="{Binding DataContext.AddCategoryToSelectionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                        CommandParameter="{Binding}"/>
                                                                <Button Grid.Column="3" Content="−"
                                                                        Style="{StaticResource MaterialDesignFlatButton}"
                                                                        FontSize="14" Padding="8,4" Height="28"
                                                                        ToolTip="Remove this category's accounts from the selection"
                                                                        Command="{Binding DataContext.RemoveCategoryFromSelectionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                        CommandParameter="{Binding}"/>
                                                            </Grid>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </DockPanel>
                                        </TabItem>

                                        <!-- Accounts tab -->
                                        <TabItem Header="Accounts">
                                            <DockPanel Margin="0">
                                                <Grid DockPanel.Dock="Top" Margin="12,8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBox Grid.Column="0"
                                                             Text="{Binding AccountSearchText, UpdateSourceTrigger=PropertyChanged}"
                                                             materialDesign:HintAssist.Hint="Search…"
                                                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                                             Margin="0,0,8,0"/>
                                                    <Button Grid.Column="1" Content="All"
                                                            Style="{StaticResource MaterialDesignFlatButton}"
                                                            FontSize="11" Padding="8,4" Height="32"
                                                            Command="{Binding SelectAllAccountsCommand}"
                                                            ToolTip="Select all accounts"/>
                                                    <Button Grid.Column="2" Content="Clear"
                                                            Style="{StaticResource MaterialDesignFlatButton}"
                                                            FontSize="11" Padding="8,4" Height="32"
                                                            Command="{Binding ClearAccountSelectionCommand}"
                                                            ToolTip="Clear all selections"/>
                                                </Grid>
                                                <ListBox ItemsSource="{Binding AccountPicks}" MaxHeight="320"
                                                         SelectionMode="Single"
                                                         Background="Transparent" BorderThickness="0">
                                                    <ListBox.ItemContainerStyle>
                                                        <Style TargetType="ListBoxItem" BasedOn="{StaticResource MaterialDesignListBoxItem}">
                                                            <Setter Property="Padding" Value="0"/>
                                                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                                        </Style>
                                                    </ListBox.ItemContainerStyle>
                                                    <ListBox.ItemTemplate>
                                                        <DataTemplate>
                                                            <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                                      Margin="12,4">
                                                                <StackPanel>
                                                                    <TextBlock Text="{Binding Name}" FontWeight="Medium"/>
                                                                    <TextBlock Text="{Binding Username}" FontSize="11" Opacity="0.6"/>
                                                                </StackPanel>
                                                            </CheckBox>
                                                        </DataTemplate>
                                                    </ListBox.ItemTemplate>
                                                </ListBox>
                                            </DockPanel>
                                        </TabItem>
                                    </TabControl>
                                </DockPanel>
                            </materialDesign:Card>
                        </Popup>

                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                            <Button Style="{StaticResource MaterialDesignRaisedButton}"
                                    Content="▶ Run" Margin="0,0,8,0"
                                    Command="{Binding RunNowCommand}"
                                    materialDesign:ButtonAssist.CornerRadius="4"
                                    ToolTip="Run template on selected accounts (auto-opens browsers)"/>
                            <Button Style="{StaticResource MaterialDesignOutlinedButton}"
                                    Content="Run All Active" Margin="0,0,8,0"
                                    Command="{Binding RunForAllActiveAccountsCommand}"
                                    materialDesign:ButtonAssist.CornerRadius="4"
                                    ToolTip="Run on every active account, auto-opening browsers"/>
                            <Button Style="{StaticResource MaterialDesignOutlinedButton}"
                                    Content="Stop All" Foreground="IndianRed"
                                    Command="{Binding StopAllTasksCommand}"
                                    materialDesign:ButtonAssist.CornerRadius="4"/>
                        </StackPanel>
                    </Grid>

                    <!-- Row 2: Preset bar -->
                    <Grid Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <ComboBox Grid.Column="0" materialDesign:HintAssist.Hint="Preset (optional)"
                                  ItemsSource="{Binding Presets}"
                                  SelectedItem="{Binding SelectedPreset, Mode=TwoWay}"
                                  DisplayMemberPath="Name"
                                  Style="{StaticResource MaterialDesignOutlinedComboBox}" Margin="0,0,12,0"/>

                        <Button Grid.Column="1" Content="Save preset"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                Command="{Binding OpenSavePresetDialogCommand}"
                                materialDesign:ButtonAssist.CornerRadius="4"
                                Margin="0,0,8,0"
                                ToolTip="Save current template + selected accounts as a preset"/>
                        <Button Grid.Column="2" Content="Delete preset"
                                Style="{StaticResource MaterialDesignFlatButton}"
                                Foreground="IndianRed"
                                Command="{Binding DeletePresetCommand}"
                                materialDesign:ButtonAssist.CornerRadius="4"/>
                    </Grid>
                </StackPanel>
            </materialDesign:Card>

        <!-- Status -->
        <TextBlock DockPanel.Dock="Top" Text="{Binding StatusMessage}" Margin="0,0,0,8"
                   FontSize="12" Opacity="0.7"
                   Visibility="{Binding StatusMessage, Converter={StaticResource NullToVisibility}}"/>

        <!-- Running Tasks -->
        <materialDesign:Card DockPanel.Dock="Top" Padding="12" Margin="0,0,0,12"
                             Visibility="{Binding RunningTasks.Count, Converter={StaticResource CountToVisibility}}">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="Running Tasks" FontSize="14" FontWeight="Medium" Margin="0,0,0,8"/>
                <DataGrid ItemsSource="{Binding RunningTasks}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          IsReadOnly="True"
                          materialDesign:DataGridAssist.ColumnHeaderPadding="8 4"
                          materialDesign:DataGridAssist.CellPadding="8 4"
                          HeadersVisibility="Column"
                          Style="{StaticResource MaterialDesignDataGrid}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding ExecutionId}" Width="50"/>
                        <DataGridTextColumn Header="Account" Binding="{Binding AccountName}" Width="120"/>
                        <DataGridTextColumn Header="Template" Binding="{Binding TemplateName}" Width="120"/>
                        <DataGridTextColumn Header="Progress" Binding="{Binding Progress}" Width="80"/>
                        <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="80"/>
                        <DataGridTextColumn Header="Message" Binding="{Binding Message}" Width="*"/>
                        <DataGridTemplateColumn Header="Actions" Width="120">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <!-- Pause: visible when Running (not paused) -->
                                        <Button ToolTip="Pause"
                                                Command="{Binding DataContext.PauseTaskCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Width="32" Height="32" Padding="0">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignIconButton}">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsPaused}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                            <materialDesign:PackIcon Kind="Pause" Width="18" Height="18" Foreground="#FFA726"/>
                                        </Button>
                                        <!-- Resume: visible when Paused -->
                                        <Button ToolTip="Resume"
                                                Command="{Binding DataContext.ResumeTaskCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Width="32" Height="32" Padding="0">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignIconButton}">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsPaused}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                            <materialDesign:PackIcon Kind="Play" Width="18" Height="18" Foreground="#66BB6A"/>
                                        </Button>
                                        <!-- Stop -->
                                        <Button ToolTip="Stop"
                                                Command="{Binding DataContext.StopTaskCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Width="32" Height="32" Padding="0">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignIconButton}"/>
                                            </Button.Style>
                                            <materialDesign:PackIcon Kind="Stop" Width="18" Height="18" Foreground="#EF5350"/>
                                        </Button>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </materialDesign:Card>

        <!-- Execution History -->
        <DockPanel>
            <Grid DockPanel.Dock="Top" Margin="0,0,0,8">
                <TextBlock Text="Execution History" FontSize="16" FontWeight="Medium" VerticalAlignment="Center"/>
                <Button Content="Clear All" HorizontalAlignment="Right"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        Command="{Binding ClearHistoryCommand}"
                        Foreground="IndianRed"
                        materialDesign:ButtonAssist.CornerRadius="4"
                        Height="28" FontSize="11" Padding="12,0"/>
            </Grid>
            <DataGrid ItemsSource="{Binding ExecutionHistory}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      IsReadOnly="True"
                      materialDesign:DataGridAssist.ColumnHeaderPadding="8 4"
                      materialDesign:DataGridAssist.CellPadding="8 4"
                      HeadersVisibility="Column"
                      Style="{StaticResource MaterialDesignDataGrid}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                    <DataGridTextColumn Header="Template" Binding="{Binding ActionTemplate.Name}" Width="120"/>
                    <DataGridTextColumn Header="Account" Binding="{Binding Account.Name}" Width="120"/>
                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="80"/>
                    <DataGridTextColumn Header="Steps" Binding="{Binding TotalSteps}" Width="50"/>
                    <DataGridTextColumn Header="Started" Binding="{Binding StartedAt, StringFormat='{}{0:MM/dd HH:mm}'}" Width="110"/>
                    <DataGridTextColumn Header="Completed" Binding="{Binding CompletedAt, StringFormat='{}{0:MM/dd HH:mm}'}" Width="110"/>
                    <DataGridTextColumn Header="Error" Binding="{Binding ErrorMessage}" Width="*"/>
                    <DataGridTemplateColumn Header="" Width="40">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button ToolTip="Delete"
                                        Command="{Binding DataContext.DeleteExecutionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"
                                        Width="28" Height="28" Padding="0"
                                        Style="{StaticResource MaterialDesignIconButton}">
                                    <materialDesign:PackIcon Kind="Delete" Width="16" Height="16" Foreground="#EF5350"/>
                                </Button>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </DockPanel>
        </DockPanel>

        <!-- Save Preset modal overlay -->
        <Grid Background="#80000000"
              Visibility="{Binding IsSavePresetDialogOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
            <materialDesign:Card Width="360" Padding="20" VerticalAlignment="Center" HorizontalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="Save preset" FontSize="18" FontWeight="Medium" Margin="0,0,0,12"/>
                    <TextBlock Margin="0,0,0,8" FontSize="12" Opacity="0.7" TextWrapping="Wrap"
                               Text="Saves the current template + selected accounts under a name. Re-using a name overwrites the existing preset."/>
                    <TextBox materialDesign:HintAssist.Hint="Preset name"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             Text="{Binding PresetNameInput, UpdateSourceTrigger=PropertyChanged}"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                        <Button Content="Cancel" Style="{StaticResource MaterialDesignFlatButton}"
                                Command="{Binding CancelSavePresetCommand}" Margin="0,0,8,0"/>
                        <Button Content="Save" Style="{StaticResource MaterialDesignRaisedButton}"
                                Command="{Binding ConfirmSavePresetCommand}"
                                IsDefault="True"/>
                    </StackPanel>
                </StackPanel>
            </materialDesign:Card>
        </Grid>
    </Grid>
</UserControl>
