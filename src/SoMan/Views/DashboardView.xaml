<UserControl x:Class="SoMan.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:vm="clr-namespace:SoMan.ViewModels"
             d:DataContext="{d:DesignInstance vm:DashboardViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24">
        <StackPanel>
            <TextBlock Text="Dashboard" FontSize="24" FontWeight="Bold" Margin="0,0,0,20" />

            <!-- Summary Cards -->
            <UniformGrid Columns="4" Margin="0,0,0,20">
                <materialDesign:Card Margin="0,0,12,0" Padding="20">
                    <StackPanel>
                        <TextBlock Text="Total Accounts" Opacity="0.6" FontSize="12" />
                        <TextBlock Text="{Binding TotalAccounts}" FontSize="32" FontWeight="Bold" Margin="0,4,0,0" />
                    </StackPanel>
                </materialDesign:Card>
                <materialDesign:Card Margin="6,0" Padding="20">
                    <StackPanel>
                        <TextBlock Text="Active Accounts" Opacity="0.6" FontSize="12" />
                        <TextBlock Text="{Binding ActiveAccounts}" FontSize="32" FontWeight="Bold"
                                   Foreground="{DynamicResource PrimaryHueMidBrush}" Margin="0,4,0,0" />
                    </StackPanel>
                </materialDesign:Card>
                <materialDesign:Card Margin="6,0" Padding="20">
                    <StackPanel>
                        <TextBlock Text="Running Tasks" Opacity="0.6" FontSize="12" />
                        <TextBlock Text="{Binding RunningTasks}" FontSize="32" FontWeight="Bold"
                                   Foreground="LimeGreen" Margin="0,4,0,0" />
                    </StackPanel>
                </materialDesign:Card>
                <materialDesign:Card Margin="12,0,0,0" Padding="20">
                    <StackPanel>
                        <TextBlock Text="Errors Today" Opacity="0.6" FontSize="12" />
                        <TextBlock Text="{Binding ErrorsToday}" FontSize="32" FontWeight="Bold"
                                   Foreground="IndianRed" Margin="0,4,0,0" />
                    </StackPanel>
                </materialDesign:Card>
            </UniformGrid>

            <!-- Resource Monitor -->
            <materialDesign:Card Margin="0,0,0,20" Padding="20">
                <StackPanel>
                    <TextBlock Text="Resource Monitor" FontSize="16" FontWeight="Medium" Margin="0,0,0,16" />

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="60" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="CPU" VerticalAlignment="Center" />
                        <ProgressBar Grid.Column="1" Value="{Binding CpuUsage}" Maximum="100" Height="16"
                                     Style="{StaticResource MaterialDesignLinearProgressBar}" />
                        <TextBlock Grid.Column="2" Text="{Binding CpuUsage, StringFormat='{}{0:F0}%'}"
                                   HorizontalAlignment="Right" VerticalAlignment="Center" />
                    </Grid>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="60" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="RAM" VerticalAlignment="Center" />
                        <ProgressBar Grid.Column="1" Value="{Binding RamUsagePercent}" Maximum="100" Height="16"
                                     Style="{StaticResource MaterialDesignLinearProgressBar}" />
                        <TextBlock Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                            <Run Text="{Binding RamFreeMB, StringFormat='{}{0:N0}', Mode=OneWay}" />
                            <Run Text="/" />
                            <Run Text="{Binding RamTotalMB, StringFormat='{}{0:N0} MB', Mode=OneWay}" />
                        </TextBlock>
                    </Grid>

                    <TextBlock Margin="0,8,0,0" Opacity="0.6">
                        <Run Text="Available Slots: " />
                        <Run Text="{Binding AvailableSlots, Mode=OneWay}" FontWeight="Bold" />
                    </TextBlock>
                </StackPanel>
            </materialDesign:Card>

            <!-- Placeholder for Running Tasks & Activity -->
            <materialDesign:Card Padding="20">
                <StackPanel>
                    <TextBlock Text="Recent Activity" FontSize="16" FontWeight="Medium" Margin="0,0,0,12" />
                    <TextBlock Text="No activity yet. Add accounts and run templates to get started."
                               Opacity="0.5" FontStyle="Italic" />
                </StackPanel>
            </materialDesign:Card>
        </StackPanel>
    </ScrollViewer>
</UserControl>
