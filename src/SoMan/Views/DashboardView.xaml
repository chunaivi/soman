<UserControl x:Class="SoMan.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:vm="clr-namespace:SoMan.ViewModels"
             d:DataContext="{d:DesignInstance vm:DashboardViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24">
        <StackPanel>
            <TextBlock Text="Dashboard" FontSize="24" FontWeight="Bold" Margin="0,0,0,20" />

            <!-- Summary Cards -->
            <UniformGrid Columns="4" Margin="0,0,0,20">
                <materialDesign:Card Margin="0,0,12,0" Padding="20">
                    <StackPanel>
                        <TextBlock Text="Total Accounts" Opacity="0.6" FontSize="12" />
                        <TextBlock Text="{Binding TotalAccounts}" FontSize="32" FontWeight="Bold" Margin="0,4,0,0" />
                    </StackPanel>
                </materialDesign:Card>
                <materialDesign:Card Margin="6,0" Padding="20">
                    <StackPanel>
                        <TextBlock Text="Active Accounts" Opacity="0.6" FontSize="12" />
                        <TextBlock Text="{Binding ActiveAccounts}" FontSize="32" FontWeight="Bold"
                                   Foreground="{DynamicResource PrimaryHueMidBrush}" Margin="0,4,0,0" />
                    </StackPanel>
                </materialDesign:Card>
                <materialDesign:Card Margin="6,0" Padding="20">
                    <StackPanel>
                        <TextBlock Text="Running Tasks" Opacity="0.6" FontSize="12" />
                        <TextBlock Text="{Binding RunningTasks}" FontSize="32" FontWeight="Bold"
                                   Foreground="LimeGreen" Margin="0,4,0,0" />
                    </StackPanel>
                </materialDesign:Card>
                <materialDesign:Card Margin="12,0,0,0" Padding="20">
                    <StackPanel>
                        <TextBlock Text="Errors Today" Opacity="0.6" FontSize="12" />
                        <TextBlock Text="{Binding ErrorsToday}" FontSize="32" FontWeight="Bold"
                                   Foreground="IndianRed" Margin="0,4,0,0" />
                    </StackPanel>
                </materialDesign:Card>
            </UniformGrid>

            <!-- Resource Monitor -->
            <materialDesign:Card Margin="0,0,0,20" Padding="20">
                <StackPanel>
                    <TextBlock Text="Resource Monitor" FontSize="16" FontWeight="Medium" Margin="0,0,0,16" />

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="60" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="CPU" VerticalAlignment="Center" />
                        <ProgressBar Grid.Column="1" Value="{Binding CpuUsage}" Maximum="100" Height="16"
                                     Style="{StaticResource MaterialDesignLinearProgressBar}" />
                        <TextBlock Grid.Column="2" Text="{Binding CpuUsage, StringFormat='{}{0:F0}%'}"
                                   HorizontalAlignment="Right" VerticalAlignment="Center" />
                    </Grid>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="60" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="RAM" VerticalAlignment="Center" />
                        <ProgressBar Grid.Column="1" Value="{Binding RamUsagePercent}" Maximum="100" Height="16"
                                     Style="{StaticResource MaterialDesignLinearProgressBar}" />
                        <TextBlock Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                            <Run Text="{Binding RamFreeMB, StringFormat='{}{0:N0}', Mode=OneWay}" />
                            <Run Text="/" />
                            <Run Text="{Binding RamTotalMB, StringFormat='{}{0:N0} MB', Mode=OneWay}" />
                        </TextBlock>
                    </Grid>

                    <TextBlock Margin="0,8,0,0" Opacity="0.6">
                        <Run Text="Available Slots: " />
                        <Run Text="{Binding AvailableSlots, Mode=OneWay}" FontWeight="Bold" />
                    </TextBlock>
                </StackPanel>
            </materialDesign:Card>

            <!-- Recent Activity -->
            <materialDesign:Card Padding="20">
                <StackPanel>
                    <DockPanel Margin="0,0,0,12">
                        <TextBlock Text="Recent Activity" FontSize="16" FontWeight="Medium" VerticalAlignment="Center" />
                        <Button DockPanel.Dock="Right" HorizontalAlignment="Right"
                                Style="{StaticResource MaterialDesignFlatButton}"
                                Content="Refresh"
                                Command="{Binding RefreshCommand}"/>
                    </DockPanel>
                    <TextBlock Text="No activity yet. Add accounts and run templates to get started."
                               Opacity="0.5" FontStyle="Italic"
                               Visibility="{Binding RecentActivity.Count, Converter={StaticResource CountToVisibility}, ConverterParameter=Invert}"/>
                    <ItemsControl ItemsSource="{Binding RecentActivity}"
                                  Visibility="{Binding RecentActivity.Count, Converter={StaticResource CountToVisibility}}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="150"/>
                                        <ColumnDefinition Width="140"/>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding ExecutedAt, StringFormat='{}{0:yyyy-MM-dd HH:mm:ss}'}" Opacity="0.7" FontSize="12"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Account.Username}" FontSize="12"/>
                                    <TextBlock Grid.Column="2" Text="{Binding ActionType}" FontSize="12"/>
                                    <Border Grid.Column="3" CornerRadius="10" Padding="8,2" HorizontalAlignment="Left">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#555"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Result}" Value="Success">
                                                        <Setter Property="Background" Value="#2E7D32"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Result}" Value="Failed">
                                                        <Setter Property="Background" Value="#C62828"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Result}" Value="Skipped">
                                                        <Setter Property="Background" Value="#6A6A6A"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{Binding Result}" Foreground="White" FontSize="11"/>
                                    </Border>
                                    <TextBlock Grid.Column="4" Text="{Binding Details}" Opacity="0.8" FontSize="12" TextTrimming="CharacterEllipsis"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </materialDesign:Card>
        </StackPanel>
    </ScrollViewer>
</UserControl>
