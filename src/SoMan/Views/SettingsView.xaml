<UserControl x:Class="SoMan.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:vm="clr-namespace:SoMan.ViewModels"
             d:DataContext="{d:DesignInstance vm:SettingsViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24">
        <StackPanel>
            <TextBlock Text="Settings" FontSize="24" FontWeight="Bold" Margin="0,0,0,20" />

            <!-- General -->
            <materialDesign:Card Margin="0,0,0,16" Padding="20">
                <StackPanel>
                    <TextBlock Text="General" FontSize="16" FontWeight="Medium" Margin="0,0,0,16" />

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Theme" VerticalAlignment="Center" />
                        <ComboBox Grid.Column="1" Width="200" HorizontalAlignment="Left"
                                  Style="{StaticResource MaterialDesignOutlinedComboBox}">
                            <ComboBoxItem Content="Dark" IsSelected="True" />
                            <ComboBoxItem Content="Light" />
                        </ComboBox>
                    </Grid>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Start with Windows" VerticalAlignment="Center" />
                        <ToggleButton Grid.Column="1" HorizontalAlignment="Left"
                                      Style="{StaticResource MaterialDesignSwitchToggleButton}" />
                    </Grid>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Minimize to Tray" VerticalAlignment="Center" />
                        <ToggleButton Grid.Column="1" HorizontalAlignment="Left" IsChecked="True"
                                      Style="{StaticResource MaterialDesignSwitchToggleButton}" />
                    </Grid>

                    <Grid Margin="0,0,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="History Retention (days)" VerticalAlignment="Center" />
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <TextBox Width="100" HorizontalAlignment="Left"
                                     Text="{Binding HistoryRetentionDays, UpdateSourceTrigger=PropertyChanged}"
                                     materialDesign:HintAssist.Hint="0 = keep all"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}" />
                            <TextBlock Text="0 = keep forever" VerticalAlignment="Center" Margin="12,0,0,0" Opacity="0.5" FontSize="12"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </materialDesign:Card>

            <!-- Browser -->
            <materialDesign:Card Margin="0,0,0,16" Padding="20">
                <StackPanel>
                    <TextBlock Text="Browser" FontSize="16" FontWeight="Medium" Margin="0,0,0,16" />

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Default Mode" VerticalAlignment="Center" />
                        <ComboBox Grid.Column="1" Width="200" HorizontalAlignment="Left"
                                  Style="{StaticResource MaterialDesignOutlinedComboBox}">
                            <ComboBoxItem Content="Headless" IsSelected="True" />
                            <ComboBoxItem Content="Headed" />
                        </ComboBox>
                    </Grid>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Browser Engine" VerticalAlignment="Center" />
                        <ComboBox Grid.Column="1" Width="200" HorizontalAlignment="Left"
                                  Style="{StaticResource MaterialDesignOutlinedComboBox}">
                            <ComboBoxItem Content="Chromium" IsSelected="True" />
                            <ComboBoxItem Content="Firefox" />
                            <ComboBoxItem Content="WebKit" />
                        </ComboBox>
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Max Concurrent" VerticalAlignment="Center" />
                        <ComboBox Grid.Column="1" Width="200" HorizontalAlignment="Left"
                                  Style="{StaticResource MaterialDesignOutlinedComboBox}">
                            <ComboBoxItem Content="Auto (based on resource)" IsSelected="True" />
                            <ComboBoxItem Content="Manual Override" />
                        </ComboBox>
                    </Grid>
                </StackPanel>
            </materialDesign:Card>

            <!-- Delay -->
            <materialDesign:Card Margin="0,0,0,16" Padding="20">
                <StackPanel>
                    <TextBlock Text="Delay Settings" FontSize="16" FontWeight="Medium" Margin="0,0,0,16" />

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="20" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Between Actions" VerticalAlignment="Center" />
                        <TextBox Grid.Column="1" Width="100" Text="3000"
                                 materialDesign:HintAssist.Hint="Min (ms)"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}" />
                        <TextBox Grid.Column="3" Width="100" Text="10000"
                                 materialDesign:HintAssist.Hint="Max (ms)"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}" />
                    </Grid>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="20" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Between Accounts" VerticalAlignment="Center" />
                        <TextBox Grid.Column="1" Width="100" Text="5000"
                                 materialDesign:HintAssist.Hint="Min (ms)"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}" />
                        <TextBox Grid.Column="3" Width="100" Text="15000"
                                 materialDesign:HintAssist.Hint="Max (ms)"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}" />
                    </Grid>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Jitter (%)" VerticalAlignment="Center" />
                        <TextBox Grid.Column="1" Width="100" Text="20" HorizontalAlignment="Left"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}" />
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Human Simulation" VerticalAlignment="Center" />
                        <ToggleButton Grid.Column="1" HorizontalAlignment="Left" IsChecked="True"
                                      Style="{StaticResource MaterialDesignSwitchToggleButton}" />
                    </Grid>
                </StackPanel>
            </materialDesign:Card>

            <!-- Resource Limits -->
            <materialDesign:Card Margin="0,0,0,16" Padding="20">
                <StackPanel>
                    <TextBlock Text="Resource Limits" FontSize="16" FontWeight="Medium" Margin="0,0,0,16" />

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Max CPU Usage (%)" VerticalAlignment="Center" />
                        <TextBox Grid.Column="1" Width="100" Text="85" HorizontalAlignment="Left"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}" />
                    </Grid>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Min Free RAM (%)" VerticalAlignment="Center" />
                        <TextBox Grid.Column="1" Width="100" Text="20" HorizontalAlignment="Left"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}" />
                    </Grid>
                </StackPanel>
            </materialDesign:Card>

            <!-- Save Button -->
            <Button Content="Save Settings" HorizontalAlignment="Right"
                    Style="{StaticResource MaterialDesignRaisedButton}"
                    Command="{Binding SaveSettingsCommand}"
                    materialDesign:ButtonAssist.CornerRadius="4"
                    Width="150" Margin="0,0,0,16" />

            <!-- Category Management -->
            <materialDesign:Card Margin="0,0,0,16" Padding="20">
                <StackPanel>
                    <TextBlock Text="Categories" FontSize="16" FontWeight="Medium" Margin="0,0,0,16" />

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <TextBox materialDesign:HintAssist.Hint="Category Name"
                                 Text="{Binding NewCategoryName, UpdateSourceTrigger=PropertyChanged}"
                                 Width="200" Margin="0,0,12,0"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"/>

                        <!-- Color Picker -->
                        <materialDesign:PopupBox PlacementMode="BottomAndAlignLeftEdges" StaysOpen="True"
                                                 Margin="0,0,12,0" ToolTip="Pick Color">
                            <materialDesign:PopupBox.ToggleContent>
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="32" Height="32" CornerRadius="4"
                                            Background="{Binding NewCategoryColor}" Margin="0,0,8,0"
                                            BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="1"/>
                                    <TextBlock Text="{Binding NewCategoryColor}" VerticalAlignment="Center"
                                               Foreground="{DynamicResource MaterialDesignBody}" FontSize="13"/>
                                </StackPanel>
                            </materialDesign:PopupBox.ToggleContent>
                            <materialDesign:ColorPicker Width="300" Height="200"
                                                        Color="{Binding CategoryPickerColor, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        </materialDesign:PopupBox>

                        <Button Content="Add" Style="{StaticResource MaterialDesignRaisedButton}"
                                Command="{Binding AddCategoryCommand}"
                                materialDesign:ButtonAssist.CornerRadius="4"/>
                    </StackPanel>

                    <DataGrid ItemsSource="{Binding Categories}"
                              SelectedItem="{Binding SelectedCategory}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False" CanUserDeleteRows="False"
                              IsReadOnly="True" MaxHeight="200"
                              SelectionMode="Single"
                              materialDesign:DataGridAssist.CellPadding="8 4">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*"/>
                            <DataGridTemplateColumn Header="Color" Width="60">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Width="24" Height="24" CornerRadius="12"
                                                Background="{Binding Color}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Accounts" Binding="{Binding Accounts.Count}" Width="70"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <Button Content="Delete Selected" Style="{StaticResource MaterialDesignOutlinedButton}"
                            Command="{Binding DeleteCategoryCommand}"
                            Margin="0,8,0,0" HorizontalAlignment="Left"
                            materialDesign:ButtonAssist.CornerRadius="4"/>
                </StackPanel>
            </materialDesign:Card>

            <!-- Proxy Management -->
            <materialDesign:Card Margin="0,0,0,16" Padding="20">
                <StackPanel>
                    <TextBlock Text="Proxy Management" FontSize="16" FontWeight="Medium" Margin="0,0,0,16" />

                    <!-- Add single proxy -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <ComboBox materialDesign:HintAssist.Hint="Type"
                                  ItemsSource="{Binding ProxyTypeOptions}"
                                  SelectedItem="{Binding NewProxyType}"
                                  Width="100" Margin="0,0,8,0"
                                  Style="{StaticResource MaterialDesignOutlinedComboBox}"/>
                        <TextBox materialDesign:HintAssist.Hint="Host"
                                 Text="{Binding NewProxyHost, UpdateSourceTrigger=PropertyChanged}"
                                 Width="180" Margin="0,0,8,0"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
                        <TextBox materialDesign:HintAssist.Hint="Port"
                                 Text="{Binding NewProxyPort, UpdateSourceTrigger=PropertyChanged}"
                                 Width="80" Margin="0,0,8,0"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
                        <TextBox materialDesign:HintAssist.Hint="User"
                                 Text="{Binding NewProxyUser, UpdateSourceTrigger=PropertyChanged}"
                                 Width="120" Margin="0,0,8,0"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
                        <TextBox materialDesign:HintAssist.Hint="Pass"
                                 Text="{Binding NewProxyPass, UpdateSourceTrigger=PropertyChanged}"
                                 Width="120" Margin="0,0,8,0"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
                        <Button Content="Add" Style="{StaticResource MaterialDesignRaisedButton}"
                                Command="{Binding AddProxyCommand}"
                                materialDesign:ButtonAssist.CornerRadius="4"/>
                    </StackPanel>

                    <!-- Proxy list -->
                    <DataGrid ItemsSource="{Binding ProxyList}"
                              SelectedItem="{Binding SelectedProxy}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False" CanUserDeleteRows="False"
                              IsReadOnly="True" MaxHeight="200"
                              SelectionMode="Single"
                              materialDesign:DataGridAssist.CellPadding="8 4">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*"/>
                            <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="70"/>
                            <DataGridTextColumn Header="Host" Binding="{Binding Host}" Width="150"/>
                            <DataGridTextColumn Header="Port" Binding="{Binding Port}" Width="70"/>
                            <DataGridTextColumn Header="Active" Binding="{Binding IsActive}" Width="60"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <Button Content="Delete Selected" Style="{StaticResource MaterialDesignOutlinedButton}"
                                Command="{Binding DeleteProxyCommand}"
                                materialDesign:ButtonAssist.CornerRadius="4" Margin="0,0,12,0"/>
                    </StackPanel>

                    <!-- Bulk import -->
                    <TextBlock Text="Bulk Import (host:port or host:port:user:pass, one per line)" Margin="0,16,0,4" Opacity="0.6"/>
                    <TextBox Text="{Binding BulkProxyText, UpdateSourceTrigger=PropertyChanged}"
                             AcceptsReturn="True" TextWrapping="Wrap"
                             MinHeight="60" MaxHeight="120"
                             VerticalScrollBarVisibility="Auto"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             Margin="0,0,0,8"/>
                    <Button Content="Import Proxies" Style="{StaticResource MaterialDesignRaisedButton}"
                            Command="{Binding ImportProxiesCommand}"
                            HorizontalAlignment="Left"
                            materialDesign:ButtonAssist.CornerRadius="4"/>
                </StackPanel>
            </materialDesign:Card>

            <!-- Status message -->
            <TextBlock Text="{Binding ErrorMessage}" Foreground="Orange" Margin="0,0,0,24"
                       TextWrapping="Wrap"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
