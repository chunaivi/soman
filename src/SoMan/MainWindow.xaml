<Window x:Class="SoMan.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:vm="clr-namespace:SoMan.ViewModels"
        xmlns:views="clr-namespace:SoMan.Views"
        mc:Ignorable="d"
        Title="SoMan — Social Media Manager"
        Height="720" Width="1280"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Style="{StaticResource MaterialDesignWindow}"
        Background="{DynamicResource MaterialDesignPaper}"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        TextElement.FontWeight="Regular"
        TextElement.FontSize="13"
        d:DataContext="{d:DesignInstance vm:MainViewModel}">

    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
            <views:DashboardView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:AccountListViewModel}">
            <views:AccountListView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:TaskListViewModel}">
            <views:TaskListView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:TemplateEditorViewModel}">
            <views:TemplateEditorView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SchedulerViewModel}">
            <views:SchedulerView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:LogViewModel}">
            <views:LogView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
            <views:SettingsView />
        </DataTemplate>
    </Window.Resources>

    <DockPanel>
        <!-- Status Bar -->
        <StatusBar DockPanel.Dock="Bottom" Background="{DynamicResource MaterialDesignToolBarBackground}">
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="Play" Width="14" Height="14" Margin="0,0,4,0" VerticalAlignment="Center" />
                    <TextBlock>
                        <Run Text="Running: " />
                        <Run Text="{Binding RunningTasks, Mode=OneWay}" />
                        <Run Text="/" />
                        <Run Text="{Binding TotalTasks, Mode=OneWay}" />
                    </TextBlock>
                </StackPanel>
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="Cpu64Bit" Width="14" Height="14" Margin="0,0,4,0" VerticalAlignment="Center" />
                    <TextBlock>
                        <Run Text="CPU: " />
                        <Run Text="{Binding CpuUsage, StringFormat='{}{0:F0}%', Mode=OneWay}" />
                    </TextBlock>
                </StackPanel>
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="Memory" Width="14" Height="14" Margin="0,0,4,0" VerticalAlignment="Center" />
                    <TextBlock>
                        <Run Text="RAM: " />
                        <Run Text="{Binding RamUsedMB, StringFormat='{}{0:F1}', Mode=OneWay}" />
                        <Run Text="/" />
                        <Run Text="{Binding RamTotalMB, StringFormat='{}{0:F1} MB', Mode=OneWay}" />
                    </TextBlock>
                </StackPanel>
            </StatusBarItem>
        </StatusBar>

        <!-- Main Layout: Sidebar + Content -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Sidebar -->
            <Border Grid.Column="0" Background="{DynamicResource MaterialDesignCardBackground}"
                    BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="0,0,1,0">
                <DockPanel>
                    <!-- Logo / Title -->
                    <Border DockPanel.Dock="Top" Padding="16,20,16,16">
                        <StackPanel>
                            <TextBlock Text="SoMan" FontSize="24" FontWeight="Bold"
                                       Foreground="{DynamicResource PrimaryHueMidBrush}" />
                            <TextBlock Text="Social Media Manager" FontSize="11" Opacity="0.6" Margin="0,2,0,0" />
                        </StackPanel>
                    </Border>

                    <!-- Theme Toggle -->
                    <Border DockPanel.Dock="Bottom" Padding="16,8">
                        <Button Style="{StaticResource MaterialDesignFlatButton}"
                                Command="{Binding ToggleThemeCommand}"
                                HorizontalAlignment="Left">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="ThemeLightDark" />
                                <TextBlock Text="Toggle Theme" Margin="8,0,0,0" />
                            </StackPanel>
                        </Button>
                    </Border>

                    <!-- Navigation Items -->
                    <ListBox Margin="0,8,0,0"
                             SelectedIndex="{Binding SelectedMenuIndex}"
                             Style="{StaticResource MaterialDesignNavigationPrimaryListBox}">

                        <ListBoxItem Padding="16,12" Tag="Dashboard"
                                     PreviewMouseLeftButtonUp="NavItem_Click">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="ViewDashboard" Width="20" Height="20" />
                                <TextBlock Text="Dashboard" Margin="16,0,0,0" VerticalAlignment="Center" />
                            </StackPanel>
                        </ListBoxItem>

                        <ListBoxItem Padding="16,12" Tag="Accounts"
                                     PreviewMouseLeftButtonUp="NavItem_Click">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="AccountMultiple" Width="20" Height="20" />
                                <TextBlock Text="Accounts" Margin="16,0,0,0" VerticalAlignment="Center" />
                            </StackPanel>
                        </ListBoxItem>

                        <ListBoxItem Padding="16,12" Tag="Tasks"
                                     PreviewMouseLeftButtonUp="NavItem_Click">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="PlayCircle" Width="20" Height="20" />
                                <TextBlock Text="Tasks" Margin="16,0,0,0" VerticalAlignment="Center" />
                            </StackPanel>
                        </ListBoxItem>

                        <ListBoxItem Padding="16,12" Tag="Templates"
                                     PreviewMouseLeftButtonUp="NavItem_Click">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="FileDocument" Width="20" Height="20" />
                                <TextBlock Text="Templates" Margin="16,0,0,0" VerticalAlignment="Center" />
                            </StackPanel>
                        </ListBoxItem>

                        <ListBoxItem Padding="16,12" Tag="Scheduler"
                                     PreviewMouseLeftButtonUp="NavItem_Click">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="CalendarClock" Width="20" Height="20" />
                                <TextBlock Text="Scheduler" Margin="16,0,0,0" VerticalAlignment="Center" />
                            </StackPanel>
                        </ListBoxItem>

                        <ListBoxItem Padding="16,12" Tag="Logs"
                                     PreviewMouseLeftButtonUp="NavItem_Click">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="TextBoxMultiple" Width="20" Height="20" />
                                <TextBlock Text="Logs" Margin="16,0,0,0" VerticalAlignment="Center" />
                            </StackPanel>
                        </ListBoxItem>

                        <ListBoxItem Padding="16,12" Tag="Settings"
                                     PreviewMouseLeftButtonUp="NavItem_Click">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Cog" Width="20" Height="20" />
                                <TextBlock Text="Settings" Margin="16,0,0,0" VerticalAlignment="Center" />
                            </StackPanel>
                        </ListBoxItem>
                    </ListBox>
                </DockPanel>
            </Border>

            <!-- Content Area -->
            <ContentControl Grid.Column="1"
                            Content="{Binding CurrentView}"
                            Margin="0" />
        </Grid>
    </DockPanel>
</Window>
